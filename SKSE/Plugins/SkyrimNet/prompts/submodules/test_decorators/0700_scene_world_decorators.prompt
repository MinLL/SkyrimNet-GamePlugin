- **{{ ref.name }}** ({{ ref.type }}/{{ ref.subtype }})
  - FormID: {{ ref.formID }}
  - Position: {{ ref.position.meters }}m {{ ref.position.cardinalDirection }} ({{ ref.position.direction }})
{% if ref.locked  %}  - Locked: {% if ref.locked %}🔒 Yes{% else %}🔓 No{% endif %}{% endif %}
{% endif %}
{% endfor %}
